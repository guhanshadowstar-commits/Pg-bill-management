# Live mode (recommended for Vercel): set these 2 values
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# PG owner login
# Normal owner accounts are created from the app login screen.
# Optional emergency fallback: username=password pairs separated by commas.
# Example: admin=StrongPassword1
PG_OWNER_ACCOUNTS=

# Optional one-owner emergency fallback. You can leave these blank.
PG_OWNER_USERNAME=owner
PG_OWNER_PASSWORD=
OWNER_SESSION_SECRET=

# Optional AI mode
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional app brand values
PG_NAME=Royal Stay PG
PG_LOGO_URL=
